# ─── Supabase ───
VITE_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...votre_clé_publique_ici
# Utilisée uniquement localement pour exécuter des scripts de test/migration (ne pas commettre sa valeur !)
VITE_SUPABASE_SERVICE_ROLE_KEY=eyJhbG...votre_clé_service_role_ici

# ─── Google Sheets Webhooks (URLs des Apps Script déployés) ───
VITE_GOOGLE_SHEET_ONBOARDING_WEBHOOK_URL=https://script.google.com/macros/s/VOTRE_ID_ONBOARDING/exec
VITE_GOOGLE_SHEET_BILAN_WEBHOOK_URL=https://script.google.com/macros/s/VOTRE_ID_BILAN/exec
# Clé secrète de sécurité partagée pour authentifier les envois de formulaires
VITE_GOOGLE_SHEETS_WEBHOOK_SECRET=votre_secret_partagé_webhook_ici

